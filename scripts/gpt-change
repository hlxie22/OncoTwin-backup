#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage:"
  echo "  scripts/gpt-change \"Add a dark mode toggle to the settings page\""
  echo "  scripts/gpt-change --file task.md"
  echo
  echo "Optional:"
  echo "  GPT_CHANGE_OUT_ROOT=/tmp scripts/gpt-change \"task\""
  exit 1
}

if [ "$#" -eq 0 ]; then
  usage
fi

TASK=""

if [ "$1" = "--file" ] || [ "$1" = "-f" ]; then
  if [ "$#" -lt 2 ]; then
    usage
  fi

  TASK_FILE="$2"

  if [ ! -f "$TASK_FILE" ]; then
    echo "Task file not found: $TASK_FILE"
    exit 1
  fi

  TASK="$(cat "$TASK_FILE")"
else
  TASK="$*"
fi

STAMP="$(date +%Y%m%d-%H%M%S)"
OUT_ROOT="${GPT_CHANGE_OUT_ROOT:-/tmp}"
DIR="$OUT_ROOT/gpt-change-$STAMP"

REPO="$DIR/repomix.xml"
PROMPT="$DIR/chatgpt-prompt.md"

mkdir -p "$DIR"

echo "Task:"
echo "$TASK"
echo

echo "Generating full Repomix repository context..."
echo

npx --yes repomix@latest \
  --style xml \
  --output "$REPO"

CURRENT_BRANCH="$(git branch --show-current 2>/dev/null || true)"
GIT_STATUS="$(git status --short 2>/dev/null || true)"

{
  echo "# ChatGPT Code Change Request"
  echo
  echo "You are helping me modify this repository."
  echo
  echo "The repository context below is a full, current, uncompressed Repomix dump."
  echo "The requested change is described in the task section."
  echo
  echo "## Task"
  echo
  echo "$TASK"
  echo
  echo "## Development Philosophy"
  echo
  echo "This is an early-stage repository. Optimize for a clean, coherent implementation that fits the requested behavior, not necessarily the smallest possible diff."
  echo
  echo "It is okay to make broad changes when they simplify the design, remove obsolete patterns, or better support the requested behavior. Avoid unnecessary complexity, but do not preserve poor structure just to keep the patch small."
  echo
  echo "Use the existing codebase as guidance for style, naming, architecture, and test conventions. When existing patterns are weak or inconsistent, choose the cleanest straightforward approach."
  echo
  echo "## Implementation Expectations"
  echo
  echo "Before writing the patch, reason briefly about:"
  echo "- what behavior should change"
  echo "- which existing patterns in the repo are relevant"
  echo "- how the change should be verified"
  echo
  echo "When there are multiple reasonable approaches, choose the one that is most maintainable for a small or early-stage codebase and briefly explain the choice."
  echo
  echo "Prefer completing the change properly over adding compatibility shims, aliases, fallbacks, or duplicate paths that are not clearly needed. Delete obsolete code when your change makes it unnecessary."
  echo
  echo "Use the repository's existing package manager, runtime, framework, and test style. Do not switch tools or introduce new dependencies unless the task clearly requires it."
  echo
  echo "## Test-Aware Expectations"
  echo
  echo "For behavior changes, new features, bug-prone logic, or important refactors, include meaningful tests when the repository already has a suitable test pattern."
  echo
  echo "Prefer tests that verify externally observable behavior rather than implementation details."
  echo
  echo "Do not add fake, trivial, or overly brittle tests just to appear test-driven."
  echo
  echo "When tests are not appropriate, briefly explain why."
  echo
  echo "## Documentation Expectations"
  echo
  echo "Update docs, README text, examples, or changelog entries when the requested change affects user-visible behavior, setup, commands, configuration, or public API."
  echo
  echo "Do not update docs for purely internal changes unless it would help future maintainers."
  echo
  echo "Use brief inline comments only for tricky, bug-prone, or non-obvious logic."
  echo
  echo "## Required Response Format"
  echo
  echo "Return exactly this structure:"
  echo
  echo "1. A brief implementation summary in 3-6 sentences."
  echo "2. Important design choices, assumptions, and testing decisions."
  echo "3. One terminal-pasteable shell block that:"
  echo "   - writes a unified diff to /tmp/chatgpt.patch"
  echo "   - runs git apply --check /tmp/chatgpt.patch"
  echo "   - applies the patch only if the check passes"
  echo "4. The exact command or commands I should run afterward to verify the change."
  echo
  echo "Important rules:"
  echo "- Optimize for a clean implementation, not necessarily the smallest diff."
  echo "- Avoid speculative abstractions or configurability that the task does not need."
  echo "- Follow existing project style where it is useful."
  echo "- Improve existing structure when the task benefits from it."
  echo "- Add or update meaningful tests when they provide confidence."
  echo "- Do not modify lockfiles, generated files, or snapshots unless clearly necessary."
  echo "- Do not introduce new dependencies without explicitly explaining why."
  echo "- The shell block should be directly pasteable into my terminal."
  echo "- The patch must use paths relative to the repository root."
  echo
  echo "The shell block should look like this pattern:"
  echo
  echo '```bash'
  echo "cat > /tmp/chatgpt.patch <<'PATCH'"
  echo "diff --git a/path/to/file b/path/to/file"
  echo "--- a/path/to/file"
  echo "+++ b/path/to/file"
  echo "@@ ..."
  echo "PATCH"
  echo
  echo "git apply --check /tmp/chatgpt.patch && git apply /tmp/chatgpt.patch"
  echo '```'
  echo
  echo "## Git Branch"
  echo
  echo '```text'
  echo "${CURRENT_BRANCH:-unknown}"
  echo '```'
  echo
  echo "## Git Status"
  echo
  echo '```text'
  if [ -n "$GIT_STATUS" ]; then
    echo "$GIT_STATUS"
  else
    echo "clean"
  fi
  echo '```'
  echo
  echo "## Full Current Repository Context"
  echo
  echo '```xml'
  cat "$REPO"
  echo '```'
} > "$PROMPT"

echo
echo "Generated files:"
echo "  Prompt:       $PROMPT"
echo "  Repomix repo: $REPO"
echo

echo "Next step:"
echo "  Paste or upload this file to ChatGPT:"
echo "  $PROMPT"
echo

if command -v pbcopy >/dev/null 2>&1; then
  pbcopy < "$PROMPT"
  echo "Copied prompt to clipboard with pbcopy."
elif command -v xclip >/dev/null 2>&1; then
  xclip -selection clipboard < "$PROMPT"
  echo "Copied prompt to clipboard with xclip."
elif command -v wl-copy >/dev/null 2>&1; then
  wl-copy < "$PROMPT"
  echo "Copied prompt to clipboard with wl-copy."
else
  echo "Clipboard tool not found, so copy/upload the prompt file manually."
fi
