{
  "$id": "https://oncotwin.local/schemas/mechanistic_simulator/resolved_params.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Fully resolved simulator parameter set. Prior configs use prior_config.schema.json.",
  "properties": {
    "carrying_capacity_ml": {
      "exclusiveMinimum": 0,
      "type": "number"
    },
    "drug_decay": {
      "additionalProperties": {
        "exclusiveMinimum": 0,
        "type": "number"
      },
      "minProperties": 1,
      "type": "object"
    },
    "drug_ec50": {
      "additionalProperties": {
        "exclusiveMinimum": 0,
        "type": "number"
      },
      "minProperties": 1,
      "type": "object"
    },
    "drug_sensitivity": {
      "additionalProperties": {
        "maximum": 1,
        "minimum": 0,
        "type": "number"
      },
      "minProperties": 1,
      "type": "object"
    },
    "growth_law": {
      "const": "logistic"
    },
    "growth_rate": {
      "maximum": 0.1,
      "minimum": 0,
      "type": "number"
    },
    "observation_noise_fraction": {
      "maximum": 1,
      "minimum": 0,
      "type": "number"
    },
    "particle_id": {
      "type": "string"
    },
    "resistant_fraction": {
      "maximum": 1,
      "minimum": 0,
      "type": "number"
    },
    "resistant_sensitivity_scale": {
      "maximum": 1,
      "minimum": 0,
      "type": "number"
    }
  },
  "required": [
    "growth_law",
    "growth_rate",
    "carrying_capacity_ml",
    "drug_sensitivity",
    "drug_ec50",
    "drug_decay",
    "resistant_fraction",
    "resistant_sensitivity_scale",
    "observation_noise_fraction"
  ],
  "title": "Resolved mechanistic simulator parameters",
  "type": "object"
}
