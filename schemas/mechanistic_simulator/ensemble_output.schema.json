{
  "$id": "https://oncotwin.local/schemas/mechanistic_simulator/ensemble_output.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Multi-particle ensemble output. Single runs use single_trajectory_output.schema.json.",
  "properties": {
    "case_id": {
      "type": "string"
    },
    "driver_summary": {
      "type": "object"
    },
    "final_residual_burden_distribution": {
      "type": "object"
    },
    "interval_80_volume_ml": {
      "items": {
        "items": {
          "minimum": 0,
          "type": "number"
        },
        "maxItems": 2,
        "minItems": 2,
        "type": "array"
      },
      "type": "array"
    },
    "interval_95_volume_ml": {
      "items": {
        "items": {
          "minimum": 0,
          "type": "number"
        },
        "maxItems": 2,
        "minItems": 2,
        "type": "array"
      },
      "type": "array"
    },
    "maximum_uncertainty_day": {
      "type": "number"
    },
    "median_volume_ml": {
      "items": {
        "minimum": 0,
        "type": "number"
      },
      "type": "array"
    },
    "n_particles": {
      "minimum": 1,
      "type": "integer"
    },
    "particle_trajectories": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "likelihood": {
            "type": "number"
          },
          "likelihood_placeholder": {
            "type": [
              "number",
              "null"
            ]
          },
          "parameters": {
            "$id": "https://oncotwin.local/schemas/mechanistic_simulator/resolved_params.schema.json",
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "additionalProperties": false,
            "description": "Fully resolved simulator parameter set. Prior configs use prior_config.schema.json.",
            "properties": {
              "carrying_capacity_ml": {
                "exclusiveMinimum": 0,
                "type": "number"
              },
              "drug_decay": {
                "additionalProperties": {
                  "exclusiveMinimum": 0,
                  "type": "number"
                },
                "minProperties": 1,
                "type": "object"
              },
              "drug_ec50": {
                "additionalProperties": {
                  "exclusiveMinimum": 0,
                  "type": "number"
                },
                "minProperties": 1,
                "type": "object"
              },
              "drug_sensitivity": {
                "additionalProperties": {
                  "maximum": 1,
                  "minimum": 0,
                  "type": "number"
                },
                "minProperties": 1,
                "type": "object"
              },
              "growth_law": {
                "const": "logistic"
              },
              "growth_rate": {
                "maximum": 0.1,
                "minimum": 0,
                "type": "number"
              },
              "observation_noise_fraction": {
                "maximum": 1,
                "minimum": 0,
                "type": "number"
              },
              "particle_id": {
                "type": "string"
              },
              "resistant_fraction": {
                "maximum": 1,
                "minimum": 0,
                "type": "number"
              },
              "resistant_sensitivity_scale": {
                "maximum": 1,
                "minimum": 0,
                "type": "number"
              }
            },
            "required": [
              "growth_law",
              "growth_rate",
              "carrying_capacity_ml",
              "drug_sensitivity",
              "drug_ec50",
              "drug_decay",
              "resistant_fraction",
              "resistant_sensitivity_scale",
              "observation_noise_fraction"
            ],
            "title": "Resolved mechanistic simulator parameters",
            "type": "object"
          },
          "particle_id": {
            "type": "string"
          },
          "predicted_longest_diameter_cm": {
            "items": {
              "minimum": 0,
              "type": "number"
            },
            "type": "array"
          },
          "predicted_volume_ml": {
            "items": {
              "minimum": 0,
              "type": "number"
            },
            "type": "array"
          },
          "times": {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          "warnings": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "weight": {
            "type": "number"
          },
          "weight_placeholder": {
            "type": [
              "number",
              "null"
            ]
          }
        },
        "required": [
          "particle_id",
          "parameters",
          "times",
          "predicted_volume_ml",
          "predicted_longest_diameter_cm",
          "warnings"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "probability_final_volume_below_research_threshold": {
      "maximum": 1,
      "minimum": 0,
      "type": "number"
    },
    "research_residual_burden_threshold_ml": {
      "minimum": 0,
      "type": "number"
    },
    "simulation_version": {
      "const": "volume_ode_v0"
    },
    "times": {
      "items": {
        "type": "number"
      },
      "type": "array"
    },
    "uncertainty_score": {
      "type": "number"
    },
    "uncertainty_width_by_day": {
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "simulation_version",
    "times",
    "median_volume_ml",
    "interval_80_volume_ml",
    "interval_95_volume_ml",
    "n_particles",
    "particle_trajectories",
    "warnings",
    "driver_summary"
  ],
  "title": "Volume simulator ensemble output",
  "type": "object"
}
