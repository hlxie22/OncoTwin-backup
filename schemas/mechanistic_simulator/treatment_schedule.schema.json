{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oncotwin.local/schemas/mechanistic_simulator/treatment_schedule.schema.json",
  "title": "Treatment schedule",
  "type": "object",
  "required": ["schedule_id", "regimen_name", "total_duration_days", "events"],
  "properties": {
    "schedule_id": {
      "type": "string",
      "minLength": 1
    },
    "regimen_name": {
      "type": "string",
      "minLength": 1
    },
    "schedule_type": {
      "type": "string"
    },
    "total_duration_days": {
      "type": "number",
      "minimum": 0
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["drug", "day", "relative_dose"],
        "properties": {
          "drug": {
            "type": "string",
            "minLength": 1
          },
          "day": {
            "type": "number",
            "minimum": 0
          },
          "relative_dose": {
            "type": "number",
            "minimum": 0
          },
          "label": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
