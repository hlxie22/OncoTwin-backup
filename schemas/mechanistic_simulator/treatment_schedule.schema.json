{
  "$id": "https://oncotwin.local/schemas/mechanistic_simulator/treatment_schedule.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "events": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "day": {
            "minimum": 0,
            "type": "number"
          },
          "drug": {
            "minLength": 1,
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "relative_dose": {
            "minimum": 0,
            "type": "number"
          }
        },
        "required": [
          "drug",
          "day",
          "relative_dose"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "regimen_name": {
      "minLength": 1,
      "type": "string"
    },
    "schedule_id": {
      "minLength": 1,
      "type": "string"
    },
    "schedule_type": {
      "type": "string"
    },
    "total_duration_days": {
      "minimum": 0,
      "type": "number"
    }
  },
  "required": [
    "schedule_id",
    "regimen_name",
    "total_duration_days",
    "events"
  ],
  "title": "Treatment schedule",
  "type": "object"
}
