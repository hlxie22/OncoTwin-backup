{
  "$id": "https://oncotwin.local/schemas/mechanistic_simulator/tumor_measurement.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "anyOf": [
    {
      "required": [
        "tumor_volume_ml"
      ]
    },
    {
      "required": [
        "longest_diameter_cm"
      ]
    }
  ],
  "description": "A single tumor measurement. Case wrapper fixtures use case_fixture.schema.json.",
  "properties": {
    "case_id": {
      "minLength": 1,
      "type": "string"
    },
    "confidence": {
      "type": "string"
    },
    "day": {
      "minimum": 0,
      "type": "number"
    },
    "longest_diameter_cm": {
      "minimum": 0,
      "type": "number"
    },
    "source": {
      "enum": [
        "manual",
        "metadata",
        "mask_derived",
        "synthetic",
        "demo"
      ]
    },
    "timepoint_id": {
      "type": "string"
    },
    "true_tumor_volume_ml": {
      "minimum": 0,
      "type": "number"
    },
    "tumor_volume_ml": {
      "minimum": 0,
      "type": "number"
    }
  },
  "required": [
    "case_id",
    "day",
    "source",
    "confidence"
  ],
  "title": "Individual tumor measurement",
  "type": "object"
}
