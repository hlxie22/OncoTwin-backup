  echo '```'
  echo
  echo "## Git Status"
  echo
  echo '```text'
  if [ -n "$GIT_STATUS" ]; then
    echo "$GIT_STATUS"
  else
    echo "clean"
  fi
  echo '```'
  echo
  echo "## Command Output"
  echo
  echo '```text'
  cat "$LOG"
  echo '```'
  echo
  echo "## Full Current Repository Context"
  echo
  echo '```xml'
  cat "$REPO"
  echo '```'
} > "$PROMPT"

echo
echo "Generated files:"
