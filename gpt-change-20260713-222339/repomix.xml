            "scenario_id": "continue_chemo",
            "label": "Continue chemo",
            "treatment_schedule": chemo_schedule(),
        },
        {
            "scenario_id": "unsafe_overdose",
            "label": "Unsafe overdose preflight check",
            "treatment_schedule": chemo_schedule(relative_dose=2.0),
        },
