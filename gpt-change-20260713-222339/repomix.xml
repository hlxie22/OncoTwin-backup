<file path="scripts/gpt-bug">
#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -eq 0 ]; then
  echo "Usage:"
  echo "  scripts/gpt-bug \"npm test\""
  echo "  scripts/gpt-bug \"npm run typecheck\""
  echo "  scripts/gpt-bug \"pytest tests/test_checkout.py\""
  exit 1
fi

CMD="$*"
STAMP="$(date +%Y%m%d-%H%M%S)"
OUT_ROOT="${GPT_BUG_OUT_ROOT:-/tmp}"
DIR="$OUT_ROOT/gpt-bug-$STAMP"

LOG="$DIR/command-output.log"
REPO="$DIR/repomix.xml"
PROMPT="$DIR/chatgpt-prompt.md"

mkdir -p "$DIR"

echo "Running command:"
echo "  $CMD"
echo

set +e
bash -lc "$CMD" 2>&1 | tee "$LOG"
STATUS=${PIPESTATUS[0]}
set -e

echo
echo "Command exit status: $STATUS"
echo

echo "Generating full Repomix repository context..."
echo

npx --yes repomix@latest \
  --style xml \
  --output "$REPO"

CURRENT_BRANCH="$(git branch --show-current 2>/dev/null || true)"
GIT_STATUS="$(git status --short 2>/dev/null || true)"

{
  echo "# ChatGPT Bug Fix Request"
  echo
  echo "You are helping me fix a bug in this repository."
  echo
  echo "The repository context below is a full, current, uncompressed Repomix dump."
  echo "The command output below is the failing command I want you to diagnose."
  echo
  echo "## Your Task"
  echo
  echo "Determine the root cause of the failure and provide the smallest safe code fix."
  echo
  echo "## Required Response Format"
  echo
  echo "Return exactly this structure:"
  echo
  echo "1. A brief diagnosis in 3-6 sentences."
  echo "2. One terminal-pasteable shell block that:"
  echo "   - writes a unified diff to /tmp/chatgpt.patch"
  echo "   - runs git apply --check /tmp/chatgpt.patch"
  echo "   - applies the patch only if the check passes"
  echo "3. The exact command I should run afterward."
  echo
  echo "Important rules:"
  echo "- Make the minimal semantic fix."
  echo "- Do not refactor unrelated code."
  echo "- Do not reformat unrelated code."
  echo "- Do not change public APIs unless the bug requires it."
  echo "- Do not modify lockfiles, generated files, or snapshots unless clearly necessary."
  echo "- The shell block should be directly pasteable into my terminal."
  echo "- The patch must use paths relative to the repository root."
  echo
  echo "The shell block should look like this pattern:"
  echo
  echo '```bash'
  echo "cat > /tmp/chatgpt.patch <<'PATCH'"
  echo "diff --git a/path/to/file b/path/to/file"
  echo "--- a/path/to/file"
  echo "+++ b/path/to/file"
  echo "@@ ..."
  echo "PATCH"
  echo
  echo "git apply --check /tmp/chatgpt.patch && git apply /tmp/chatgpt.patch"
  echo '```'
  echo
  echo "## Command I Ran"
  echo
  echo '```bash'
  echo "$CMD"
  echo '```'
  echo
  echo "## Exit Status"
  echo
  echo '```text'
  echo "$STATUS"
  echo '```'
  echo
  echo "## Git Branch"
  echo
  echo '```text'
  echo "${CURRENT_BRANCH:-unknown}"
  echo '```'
  echo
  echo "## Git Status"
  echo
  echo '```text'
  if [ -n "$GIT_STATUS" ]; then
    echo "$GIT_STATUS"
  else
    echo "clean"
  fi
  echo '```'
  echo
  echo "## Command Output"
  echo
  echo '```text'
  cat "$LOG"
  echo '```'
  echo
  echo "## Full Current Repository Context"
  echo
  echo '```xml'
  cat "$REPO"
  echo '```'
} > "$PROMPT"

echo
echo "Generated files:"
echo "  Prompt:         $PROMPT"
echo "  Command output: $LOG"
echo "  Repomix repo:   $REPO"
echo

echo "Next step:"
echo "  Paste or upload this file to ChatGPT:"
echo "  $PROMPT"
echo

if command -v pbcopy >/dev/null 2>&1; then
  pbcopy < "$PROMPT"
  echo "Copied prompt to clipboard with pbcopy."
elif command -v xclip >/dev/null 2>&1; then
  xclip -selection clipboard < "$PROMPT"
  echo "Copied prompt to clipboard with xclip."
elif command -v wl-copy >/dev/null 2>&1; then
  wl-copy < "$PROMPT"
  echo "Copied prompt to clipboard with wl-copy."
else
  echo "Clipboard tool not found, so copy/upload the prompt file manually."
fi

exit "$STATUS"
</file>

<file path="slurm/ispy2_autoresubmit_controller.slurm">
#!/usr/bin/env bash
#SBATCH --job-name=ispy2-watch
#SBATCH --output=logs/slurm/ispy2-watch-%j.out
#SBATCH --error=logs/slurm/ispy2-watch-%j.err
#SBATCH --time=00:10:00
#SBATCH --cpus-per-task=1
#SBATCH --mem=1G

set -euo pipefail

RUN_DIR="${RUN_DIR:-${SLURM_SUBMIT_DIR:-$PWD}}"
cd "$RUN_DIR"

MANIFEST="${MANIFEST:?missing MANIFEST}"
PARALLELISM="${PARALLELISM:?missing PARALLELISM}"
OUTPUT_ROOT="${OUTPUT_ROOT:-data/ispy2_streaming}"
SETUP_SCRIPT="${SETUP_SCRIPT:-}"
ARRAY_SCRIPT="${ARRAY_SCRIPT:-slurm/ispy2_streaming_array.slurm}"
MERGE_SCRIPT="${MERGE_SCRIPT:-slurm/ispy2_streaming_merge.slurm}"
CONTROLLER_SCRIPT="${CONTROLLER_SCRIPT:-slurm/ispy2_autoresubmit_controller.slurm}"

PARTITION="${PARTITION:-}"
ACCOUNT="${ACCOUNT:-}"
QOS="${QOS:-}"
TIME_LIMIT="${TIME_LIMIT:-05:55:00}"
MEMORY="${MEMORY:-8G}"
CPUS="${CPUS:-2}"

MIN_FREE_SPACE_GB="${MIN_FREE_SPACE_GB:-50}"
MAX_ACTIVE_SCRATCH_GB="${MAX_ACTIVE_SCRATCH_GB:-75}"
KEEP_FAILED_DICOM="${KEEP_FAILED_DICOM:-0}"

DO_MERGE="${DO_MERGE:-1}"
CLINICAL="${CLINICAL:-}"
DEFAULT_TREATMENT_CONTEXT="${DEFAULT_TREATMENT_CONTEXT:-neoadjuvant chemotherapy}"
V1_OUTPUT="${V1_OUTPUT:-data/v1_prior_stack/processed/v1_eval_cohort.streamed.jsonl}"
RUN_V1_BUILD="${RUN_V1_BUILD:-1}"

ROUND="${ROUND:-1}"
MAX_ROUNDS="${MAX_ROUNDS:-100}"
PREVIOUS_COMPLETE="${PREVIOUS_COMPLETE:--1}"
NO_PROGRESS_ROUNDS="${NO_PROGRESS_ROUNDS:-0}"
NO_PROGRESS_LIMIT="${NO_PROGRESS_LIMIT:-3}"

mkdir -p logs/slurm "$OUTPUT_ROOT/logs"

if [ ! -f "$MANIFEST" ]; then
  echo "Manifest not found: $MANIFEST" >&2
  exit 2
fi

if [ ! -f "$ARRAY_SCRIPT" ]; then
  echo "Array script not found: $ARRAY_SCRIPT" >&2
  exit 2
fi

progress_file="$(mktemp)"
python3 - "$MANIFEST" "$OUTPUT_ROOT" > "$progress_file" <<'PY'
import csv
import json
import re
import shlex
import sys
from pathlib import Path

manifest = Path(sys.argv[1])
output_root = Path(sys.argv[2])

case_id_fields = (
    "case_id",
    "patient_id",
    "subject_id",
    "patientid",
    "dicom_patient_id",
    "submitter_case_id",
    "PatientID",
)

delimiter = "\t" if manifest.suffix.lower() in {".tsv", ".txt"} else ","
with manifest.open(newline="", encoding="utf-8") as handle:
    rows = list(csv.DictReader(handle, delimiter=delimiter))

def first_case_id(row):
    for field in case_id_fields:
        value = row.get(field)
        if value not in (None, ""):
            return str(value).strip()
    return ""

def slug(value):
    text = str(value or "").strip()
    text = re.sub(r"[^A-Za-z0-9_.-]+", "_", text)
    return text[:180] or "unknown"

case_ids = sorted({first_case_id(row) for row in rows})
case_ids = [case_id for case_id in case_ids if case_id]

complete = []
incomplete = []
failed_or_partial = []
missing_or_killed = []

for case_id in case_ids:
    status_path = output_root / "logs" / "patients" / f"{slug(case_id)}.json"
    status = {}
    if status_path.exists():
        try:
            status = json.loads(status_path.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            status = {}

    is_complete = (
        status.get("download_status")
        == status.get("extract_status")
        == status.get("feature_status")
        == "complete"
    )

    if is_complete:
        complete.append(case_id)
    else:
        incomplete.append(case_id)
        if status_path.exists():
            failed_or_partial.append(case_id)
        else:
            missing_or_killed.append(case_id)

print(f"TOTAL={len(case_ids)}")
print(f"COMPLETE={len(complete)}")
print(f"INCOMPLETE={len(incomplete)}")
print(f"FAILED_OR_PARTIAL={len(failed_or_partial)}")
print(f"MISSING_OR_KILLED={len(missing_or_killed)}")
print("FIRST_INCOMPLETE=" + shlex.quote(" ".join(incomplete[:20])))
PY

# shellcheck source=/dev/null
source "$progress_file"
rm -f "$progress_file"

echo "Round ${ROUND}: complete=${COMPLETE}/${TOTAL}, incomplete=${INCOMPLETE}, failed_or_partial=${FAILED_OR_PARTIAL}, missing_or_killed=${MISSING_OR_KILLED}"
if [ -n "${FIRST_INCOMPLETE:-}" ]; then
  echo "First incomplete cases: ${FIRST_INCOMPLETE}"
fi

if [ "$TOTAL" -lt 1 ]; then
  echo "No cases found in manifest." >&2
  exit 2
fi

if [ "$INCOMPLETE" -eq 0 ]; then
  echo "All extraction cases complete."

  if [ "$DO_MERGE" = "1" ]; then
    MERGE_SBATCH=(sbatch --parsable)
    if [ -n "$PARTITION" ]; then MERGE_SBATCH+=(--partition "$PARTITION"); fi
    if [ -n "$ACCOUNT" ]; then MERGE_SBATCH+=(--account "$ACCOUNT"); fi
    if [ -n "$QOS" ]; then MERGE_SBATCH+=(--qos "$QOS"); fi

    MERGE_SBATCH+=(
      --export "ALL,RUN_DIR=${RUN_DIR},OUTPUT_ROOT=${OUTPUT_ROOT},CLINICAL=${CLINICAL},DEFAULT_TREATMENT_CONTEXT=${DEFAULT_TREATMENT_CONTEXT},V1_OUTPUT=${V1_OUTPUT},RUN_V1_BUILD=${RUN_V1_BUILD},SETUP_SCRIPT=${SETUP_SCRIPT}"
      "$MERGE_SCRIPT"
    )

    printf 'Submitting merge job:'
    printf ' %q' "${MERGE_SBATCH[@]}"
    echo
    merge_job_id="$("${MERGE_SBATCH[@]}")"
    echo "Submitted merge job: ${merge_job_id}"
  fi

  exit 0
fi

if [ "$ROUND" -ge "$MAX_ROUNDS" ]; then
  echo "Reached MAX_ROUNDS=${MAX_ROUNDS}; stopping with ${INCOMPLETE} incomplete cases." >&2
  exit 1
fi

if [ "$COMPLETE" -eq "$PREVIOUS_COMPLETE" ]; then
  NO_PROGRESS_ROUNDS=$((NO_PROGRESS_ROUNDS + 1))
else
  NO_PROGRESS_ROUNDS=0
fi

if [ "$NO_PROGRESS_ROUNDS" -ge "$NO_PROGRESS_LIMIT" ]; then
  echo "No new completed cases after ${NO_PROGRESS_ROUNDS} controller round(s); stopping." >&2
  echo "Inspect ${OUTPUT_ROOT}/logs/errors and ${OUTPUT_ROOT}/logs/patients before resubmitting." >&2
  exit 1
fi

WORKER_COUNT="$PARALLELISM"
if [ "$WORKER_COUNT" -gt "$TOTAL" ]; then
  WORKER_COUNT="$TOTAL"
fi

ARRAY_SBATCH=(sbatch --parsable)
if [ -n "$PARTITION" ]; then ARRAY_SBATCH+=(--partition "$PARTITION"); fi
if [ -n "$ACCOUNT" ]; then ARRAY_SBATCH+=(--account "$ACCOUNT"); fi
if [ -n "$QOS" ]; then ARRAY_SBATCH+=(--qos "$QOS"); fi
if [ -n "$TIME_LIMIT" ]; then ARRAY_SBATCH+=(--time "$TIME_LIMIT"); fi
if [ -n "$MEMORY" ]; then ARRAY_SBATCH+=(--mem "$MEMORY"); fi
if [ -n "$CPUS" ]; then ARRAY_SBATCH+=(--cpus-per-task "$CPUS"); fi

ARRAY_SBATCH+=(
  --array "1-${WORKER_COUNT}"
  --export "ALL,RUN_DIR=${RUN_DIR},MANIFEST=${MANIFEST},OUTPUT_ROOT=${OUTPUT_ROOT},PATIENT_COUNT=${TOTAL},WORKER_COUNT=${WORKER_COUNT},MIN_FREE_SPACE_GB=${MIN_FREE_SPACE_GB},MAX_ACTIVE_SCRATCH_GB=${MAX_ACTIVE_SCRATCH_GB},KEEP_FAILED_DICOM=${KEEP_FAILED_DICOM},FORCE=0,SETUP_SCRIPT=${SETUP_SCRIPT}"
  "$ARRAY_SCRIPT"
)

printf 'Submitting extraction array:'
printf ' %q' "${ARRAY_SBATCH[@]}"
echo

array_job_id="$("${ARRAY_SBATCH[@]}")"
array_job_id="${array_job_id%%;*}"
echo "Submitted extraction array: ${array_job_id}"

NEXT_ROUND=$((ROUND + 1))

CTRL_SBATCH=(sbatch --parsable)
if [ -n "$PARTITION" ]; then CTRL_SBATCH+=(--partition "$PARTITION"); fi
if [ -n "$ACCOUNT" ]; then CTRL_SBATCH+=(--account "$ACCOUNT"); fi
if [ -n "$QOS" ]; then CTRL_SBATCH+=(--qos "$QOS"); fi

CTRL_SBATCH+=(
  --dependency "afterany:${array_job_id}"
  --export "ALL,RUN_DIR=${RUN_DIR},MANIFEST=${MANIFEST},PARALLELISM=${PARALLELISM},OUTPUT_ROOT=${OUTPUT_ROOT},SETUP_SCRIPT=${SETUP_SCRIPT},ARRAY_SCRIPT=${ARRAY_SCRIPT},MERGE_SCRIPT=${MERGE_SCRIPT},CONTROLLER_SCRIPT=${CONTROLLER_SCRIPT},PARTITION=${PARTITION},ACCOUNT=${ACCOUNT},QOS=${QOS},TIME_LIMIT=${TIME_LIMIT},MEMORY=${MEMORY},CPUS=${CPUS},MIN_FREE_SPACE_GB=${MIN_FREE_SPACE_GB},MAX_ACTIVE_SCRATCH_GB=${MAX_ACTIVE_SCRATCH_GB},KEEP_FAILED_DICOM=${KEEP_FAILED_DICOM},DO_MERGE=${DO_MERGE},CLINICAL=${CLINICAL},DEFAULT_TREATMENT_CONTEXT=${DEFAULT_TREATMENT_CONTEXT},V1_OUTPUT=${V1_OUTPUT},RUN_V1_BUILD=${RUN_V1_BUILD},ROUND=${NEXT_ROUND},MAX_ROUNDS=${MAX_ROUNDS},PREVIOUS_COMPLETE=${COMPLETE},NO_PROGRESS_ROUNDS=${NO_PROGRESS_ROUNDS},NO_PROGRESS_LIMIT=${NO_PROGRESS_LIMIT}"
  "$CONTROLLER_SCRIPT"
)

printf 'Submitting next controller:'
printf ' %q' "${CTRL_SBATCH[@]}"
echo

next_controller_job_id="$("${CTRL_SBATCH[@]}")"
echo "Submitted next controller: ${next_controller_job_id}"
</file>

<file path="slurm/ispy2_streaming_array.slurm">
#!/usr/bin/env bash
#SBATCH --job-name=ispy2-stream
#SBATCH --output=logs/slurm/ispy2-stream-%A_%a.out
#SBATCH --error=logs/slurm/ispy2-stream-%A_%a.err
#SBATCH --time=04:00:00
#SBATCH --cpus-per-task=2
#SBATCH --mem=8G

set -euo pipefail

mkdir -p logs/slurm

if [ -n "${SETUP_SCRIPT:-}" ]; then
  # shellcheck source=/dev/null
  source "$SETUP_SCRIPT"
fi

MANIFEST="${MANIFEST:-data/ispy2_streaming/manifests/ispy2_derived_manifest.tsv}"
SHARD_DIR="${SHARD_DIR:-}"
OUTPUT_ROOT="${OUTPUT_ROOT:-data/ispy2_streaming}"
MIN_FREE_SPACE_GB="${MIN_FREE_SPACE_GB:-50}"
MAX_ACTIVE_SCRATCH_GB="${MAX_ACTIVE_SCRATCH_GB:-75}"
KEEP_FAILED_DICOM="${KEEP_FAILED_DICOM:-0}"
FORCE="${FORCE:-0}"
PATIENT_COUNT="${PATIENT_COUNT:-}"
WORKER_COUNT="${WORKER_COUNT:-${SLURM_ARRAY_TASK_COUNT:-1}}"

if [ -z "${SLURM_ARRAY_TASK_ID:-}" ]; then
  echo "This script must be submitted as a Slurm array job." >&2
  exit 2
fi

if [ ! -f "$MANIFEST" ]; then
  echo "Missing manifest: $MANIFEST" >&2
  exit 2
fi

export OMP_NUM_THREADS="${SLURM_CPUS_PER_TASK:-2}"
export ITK_GLOBAL_DEFAULT_NUMBER_OF_THREADS="${SLURM_CPUS_PER_TASK:-2}"
export OPENBLAS_NUM_THREADS=1
export MKL_NUM_THREADS=1

run_case_index() {
  local case_index="$1"
  local cmd=(
    python3 scripts/data/ispy2_streaming_pipeline.py process
    --manifest "$MANIFEST"
  )

  if [ -n "$SHARD_DIR" ]; then
    local shard_manifest
    shard_manifest="$(printf '%s/shard_%04d.tsv' "$SHARD_DIR" "$case_index")"
    if [ ! -f "$shard_manifest" ]; then
      echo "Missing shard manifest: $shard_manifest" >&2
      return 2
    fi
    cmd+=(--shard-manifest "$shard_manifest")
  else
    cmd+=(--case-index "$case_index")
  fi

  cmd+=(
    --output-root "$OUTPUT_ROOT"
    --worker-id "$SLURM_ARRAY_TASK_ID"
    --min-free-space-gb "$MIN_FREE_SPACE_GB"
    --max-active-scratch-gb "$MAX_ACTIVE_SCRATCH_GB"
  )

  if [ "$KEEP_FAILED_DICOM" = "1" ]; then
    cmd+=(--keep-failed-dicom)
  fi
  if [ "$FORCE" = "1" ]; then
    cmd+=(--force)
  fi

  printf 'Running:'
  printf ' %q' "${cmd[@]}"
  echo
  "${cmd[@]}"
}

failures=0

if [ -n "$SHARD_DIR" ]; then
  if ! run_case_index "$SLURM_ARRAY_TASK_ID"; then
    failures=$((failures + 1))
  fi
elif [ -n "$PATIENT_COUNT" ]; then
  if ! [[ "$PATIENT_COUNT" =~ ^[1-9][0-9]*$ ]]; then
    echo "PATIENT_COUNT must be a positive integer, got: $PATIENT_COUNT" >&2
    exit 2
  fi
  if ! [[ "$WORKER_COUNT" =~ ^[1-9][0-9]*$ ]]; then
    echo "WORKER_COUNT must be a positive integer, got: $WORKER_COUNT" >&2
    exit 2
  fi

  echo "Worker ${SLURM_ARRAY_TASK_ID}/${WORKER_COUNT} processing case indices ${SLURM_ARRAY_TASK_ID}, $((SLURM_ARRAY_TASK_ID + WORKER_COUNT)), ... up to ${PATIENT_COUNT}"

  case_index="$SLURM_ARRAY_TASK_ID"
  while [ "$case_index" -le "$PATIENT_COUNT" ]; do
    if ! run_case_index "$case_index"; then
      echo "Case index failed: $case_index" >&2
      failures=$((failures + 1))
    fi
    case_index=$((case_index + WORKER_COUNT))
  done
else
  if ! run_case_index "$SLURM_ARRAY_TASK_ID"; then
    failures=$((failures + 1))
  fi
fi

if [ "$failures" -gt 0 ]; then
  echo "Worker ${SLURM_ARRAY_TASK_ID} completed with ${failures} failed case(s)." >&2
  exit 1
fi
</file>

