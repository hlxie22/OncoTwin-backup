#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage:"
  echo "  scripts/gpt-change \"Add a dark mode toggle to the settings page\""
  echo "  scripts/gpt-change --file task.md"
  echo
  echo "Optional Repomix args:"
  echo "  scripts/gpt-change \"task\" -- --ignore \"experiments/v0/**,docs/*.pdf\""
  echo
  echo "Optional:"
  echo "  GPT_CHANGE_OUT_ROOT=. scripts/gpt-change \"task\""
  exit 1
}

if [ "$#" -eq 0 ]; then
  usage
fi

TASK_ARGS=()
REPOMIX_ARGS=()

while [ "$#" -gt 0 ]; do
  if [ "$1" = "--" ]; then
    shift
    REPOMIX_ARGS=("$@")
    break
  fi

  TASK_ARGS+=("$1")
  shift
done

if [ "${#TASK_ARGS[@]}" -eq 0 ]; then
  usage
fi

if [ "${TASK_ARGS[0]}" = "--file" ] || [ "${TASK_ARGS[0]}" = "-f" ]; then
  if [ "${#TASK_ARGS[@]}" -ne 2 ]; then
    usage
  fi

  TASK_FILE="${TASK_ARGS[1]}"

  if [ ! -f "$TASK_FILE" ]; then
    echo "Task file not found: $TASK_FILE"
    exit 1
  fi

  TASK="$(cat "$TASK_FILE")"
else
  TASK="${TASK_ARGS[*]}"
fi

if [ "${#REPOMIX_ARGS[@]}" -gt 0 ]; then
  echo "Extra Repomix args: ${REPOMIX_ARGS[*]}"
fi

STAMP="$(date +%Y%m%d-%H%M%S)"
OUT_ROOT="${GPT_CHANGE_OUT_ROOT:-$PWD}"
DIR="$OUT_ROOT/gpt-change-$STAMP"

REPO="$DIR/repomix.xml"
PROMPT="$DIR/chatgpt-prompt.md"

mkdir -p "$DIR"

echo "Task:"
echo "$TASK"
echo

echo "Generating full Repomix repository context..."
echo

npx --yes repomix@latest \
  --style xml \
  "${REPOMIX_ARGS[@]}" \
  --output "$REPO"

CURRENT_BRANCH="$(git branch --show-current 2>/dev/null || true)"
GIT_STATUS="$(git status --short 2>/dev/null || true)"

{
  echo "# ChatGPT Code Change Request"
  echo
  echo "You are helping me modify this repository."
  echo
  echo "The repository context below is a full, current, uncompressed Repomix dump."
  echo "The requested change is described in the task section."
  echo
  echo "## Task"
  echo
  echo "$TASK"
  echo
  echo "## Development Philosophy"
  echo
  echo "This is an early-stage repository. Optimize for a clean, coherent implementation that fits the requested behavior, not necessarily the smallest possible diff."
  echo
  echo "It is okay to make broad changes when they simplify the design, remove obsolete patterns, or better support the requested behavior. Avoid unnecessary complexity, but do not preserve poor structure just to keep the patch small."
  echo
  echo "Use the existing codebase as guidance for style, naming, architecture, and test conventions. When existing patterns are weak or inconsistent, choose the cleanest straightforward approach."
  echo
  echo "## Implementation Expectations"
  echo
  echo "Before writing the patch, reason briefly about:"
  echo "- what behavior should change"
  echo "- which existing patterns in the repo are relevant"
  echo "- how the change should be verified"
  echo
  echo "When there are multiple reasonable approaches, choose the one that is most maintainable for a small or early-stage codebase and briefly explain the choice."
  echo
  echo "Prefer completing the change properly over adding compatibility shims, aliases, fallbacks, or duplicate paths that are not clearly needed. Delete obsolete code when your change makes it unnecessary."
  echo
  echo "Use the repository's existing package manager, runtime, framework, and test style. Do not switch tools or introduce new dependencies unless the task clearly requires it."
  echo
  echo "## Verification Expectations"
  echo
  echo "For behavior changes, new features, bug-prone logic, or important refactors, include meaningful tests when the repository already has a suitable test pattern."
  echo
  echo "For modeling, prior-stack, personalization, uncertainty, safety, scenario-lab, or explanation changes, also consider whether an evaluation, ablation, benchmark, report regeneration, or smoke check should be added or run."
  echo
  echo "For V1 layer work, explicitly say which layer-specific verification is relevant, such as unit tests, layer ablations, calibration checks, posterior-health checks, sequential forecasting evals, update-value evals, scenario-lab stability evals, or explanation-quality audits."
  echo
  echo "Prefer tests that verify externally observable behavior rather than implementation details."
